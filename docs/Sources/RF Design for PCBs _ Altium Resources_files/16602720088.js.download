"commitId": "5494151723089920", "groupId": "4971322611073024", "holdback": 0, "activation": {}, "integrationSettings": {"5136150625517568": {}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": null, "audienceName": "Everyone else", "changes": null, "id": "6529566802444288", "integrationSettings": null, "variations": [{"id": "4625901065863168", "name": "Original", "actions": []}, {"id": "5534541595541504", "name": "Variation #1", "actions": [{"viewId": "6024700778774528", "changes": [{"id": "ED35EE5D-EC23-4B64-A7BB-2A7E78E1DC30", "type": "custom_code", "value": function($){(function () {
  try {
    /* main variables */
    var debug = 0;
    var variation_name = "";
    var $;
    
    /* all Pure helper functions */
    function waitForElement(selector, trigger, delayInterval, delayTimeout) {
      var interval = setInterval(function () {
        if (
          document &&
          document.querySelector(selector) &&
          document.querySelectorAll(selector).length > 0
        ) {
          clearInterval(interval);
          trigger();
        }
      }, delayInterval);
      setTimeout(function () {
        clearInterval(interval);
      }, delayTimeout);
    }

    function init() {
      document.body.classList.add('EG-HERO-RHEIGHT');
    }

    /* Initialize variation */
    waitForElement('section.s-hero._develop-overview', init, 50, 15000);
  } catch (e) {
    if (debug) console.log(e, "error in Test" + variation_name);
  }
})();
}, "dependencies": []}, {"id": "713BDCBE-2B68-4B86-BE65-770D995CB857", "type": "append", "selector": "head", "value": "<style>@media screen and (min-width:767px) {\n    .EG-HERO-RHEIGHT section.s-hero._develop-overview {\n        min-height: unset;\n        max-height: 500px;\n    }\n}</style>", "dependencies": []}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "74C3C66D-EEE7-4238-9F33-CD8BC1D5B2CA", "selector": "a[href*=\"get-started\"], button.wds-btn._large._gap-block_md"}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "DE86443A-D0A2-40DF-B46E-175168EC098A", "selector": ".s-hero__desc .l-section__btn-group a._link"}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "4F2B0205-E885-4E14-9E74-B7B54D3EAAA3", "selector": ".s-hero__form .wds-btn'"}]}]}], "weightDistributions": [{"entityId": "4625901065863168", "endOfRange": 5000}, {"entityId": "5534541595541504", "endOfRange": 10000}], "name": "ST | FY26Q2 | Altium | TS-2486 | Reduce height of the hero banner", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "4577180651356160"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["6024700778774528"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "5079917512097792", "name": "ST | FY26Q1 | Altium | TS-2468 | Homepage - Expand the product cards on Altium homepage", "commitId": "4725083873214464", "groupId": "5571845550768128", "holdback": 0, "activation": {}, "integrationSettings": {"mixpanel": {}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": null, "audienceName": "Everyone else", "changes": null, "id": "5912949068398592", "integrationSettings": null, "variations": [{"id": "5338647348641792", "name": "Original", "actions": []}, {"id": "6425190255558656", "name": "Variation #1", "actions": [{"viewId": "5107837618094080", "changes": [{"id": "91FC4ADB-6B20-411C-93CC-21BDD211C5E4", "type": "custom_code", "value": function($){(function () {
  try {
    /* main variables */
    var debug = 0;
    var variation_name = "";
    var $;
    /* all Pure helper functions */

    function waitForElement(selector, trigger, delayInterval, delayTimeout) {
      var interval = setInterval(function () {
        if (
          document &&
          document.querySelector(selector) &&
          document.querySelectorAll(selector).length > 0
        ) {
          clearInterval(interval);
          trigger();
        }
      }, delayInterval);
      setTimeout(function () {
        clearInterval(interval);
      }, delayTimeout);
    }

    function addChecklistToCards() {
      const checklistMap = {
        "DISCOVER": [
          "Find verified components and full product solutions in minutes.",
          "Eliminate guesswork with rich context and accurate data.",
          "Reduce errors by starting with the right parts from the beginning."
        ],
        "DEVELOP": [
          "Keep version truth clear",
          "Share and review without exports",
          "Release with confidence"
        ],
        "AGILE": [
          "Adapt quickly to changes without disrupting your process.",
          "Manage projects and systems development with clarity.",
          "Deliver products on time with streamlined oversight."
        ]
      };

      document.querySelectorAll('.b-plate-columns__item').forEach(function (card) {

        const imgEl = card.querySelector('.l-section__bg img');
        const footer = card.querySelector('.b-plate-columns__footer');

        if (!imgEl || !footer || card.querySelector('.eg-checklist')) return;

        const altText = imgEl.getAttribute('alt') || '';
        let key = '';

        if (altText.toLowerCase().includes('discover')) key = 'DISCOVER';
        else if (altText.toLowerCase().includes('develop')) key = 'DEVELOP';
        else if (altText.toLowerCase().includes('agile')) key = 'AGILE';

        const items = checklistMap[key];
        if (!items) return;

        const wrapper = document.createElement('div');
        wrapper.className = 'eg-checklist';

        const ul = document.createElement('ul');

        items.forEach(text => {
          const li = document.createElement('li');
          li.textContent = text;
          ul.appendChild(li);
        });

        wrapper.appendChild(ul);
        wrapper.appendChild(footer);
        card.appendChild(wrapper);
      });
    }

    /* Variation Init */
    function init() {
      document.body.classList.add('EG-TS-2468');
      addChecklistToCards();
    }

    /* Initialize variation */
    waitForElement('.b-plate-columns__item', init, 50, 15000);
  } catch (e) {
    if (debug) console.log(e, "error in Test" + variation_name);
  }
})();
}, "dependencies": []}, {"id": "C593D0A2-603A-4ABE-A832-44B23F90D462", "type": "append", "selector": "head", "value": "<style>html body .eg-checklist {\n    background: #FFFFFF;\n    z-index: 2;\n    border-bottom-left-radius: 16px;\n    border-bottom-right-radius: 16px;\n    display: flex;\n    flex-direction: column;\n    min-height: 300px;\n}\n\nhtml body .eg-checklist ul {\n    list-style: none;\n    display: flex;\n    flex-direction: column;\n    grid-gap: 16px;\n    padding: 0;\n}\n\nhtml body .eg-checklist li {\n    font-size: 14px;\n    font-weight: 400;\n    line-height: 140%;\n    letter-spacing: -2%;\n    vertical-align: middle;\n    display: flex;\n    align-items: center;\n    grid-gap: 12px;\n    color: #111111;\n    margin: 0;\n}\n\nhtml body .eg-checklist li::before {\n    content: '';\n    background: url(https://cdn.optimizely.com/img/8453775962/a97462dd7b274ea5b560defe9426f6f3.png);\n    width: 24px;\n    height: 24px;\n    background-repeat: no-repeat;\n    background-size: contain;\n}\n\nhtml body .b-plate-columns__item {\n    padding-bottom: 0 !important;\n}\n\nhtml body .b-plate-columns__footer .b-plate-columns__products__view {\n    background: #F8F9FA;\n}\n\nhtml body .b-plate-columns__footer > a {\n    background: #1E6CF6 !important;\n    color: #FFFFFF !important;\n}\n\nhtml body .b-plate-columns__footer > a:hover {\n    background: var(--wds-controls-primary-hover) !important;\n}\n\nhtml body .b-plate-columns__item {\n    border-radius: 16px;\n}\n\n@media (min-width: 768px) {\n    html body .eg-checklist {\n        width: calc(100% + 48px);\n        margin-left: -24px;\n        padding: 24px;\n    }\n}\n\n@media (min-width: 767px) and (max-width: 1200px) {\n    html body .b-plate-columns__group .b-plate-columns__item-wrap {\n        min-height: 300px !important;\n    }\n}\n\n\n@media (min-width: 1200px) {\n    html body .eg-checklist {\n        width: calc(100% + 80px);\n        margin-left: -40px;\n        padding: 40px;\n    }\n\n    html body .b-plate-columns__footer > a {\n        font-size: 16px !important;\n    }\n\n    html body .b-plate-columns__group .b-plate-columns__item-wrap {\n        min-height: 350px !important;\n    }\n}\n\n@media (min-width: 1600px) {\n    html body .eg-checklist {\n        width: calc(100% + 100px);\n        margin-left: -50px;\n        padding: 40px 50px;\n    }\n}\n\n@media screen and (max-width: 767px) {\n    html body .eg-checklist {\n        width: calc(100% + 48px);\n        margin-left: -24px;\n        padding: 24px;\n    }\n\n    html body .b-plate-columns__group .b-plate-columns__item-wrap {\n        min-height: 280px !important;\n    }\n}</style>", "dependencies": []}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "83D429CB-5696-4A4E-B0DB-31750D585B91", "selector": ".b-plate-columns._use-hover .b-plate-columns__item a"}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "ED7362EB-4F03-4A73-A64A-7DB6803FFCB1", "selector": ".header-v2__user__btn"}]}]}], "weightDistributions": [{"entityId": "5338647348641792", "endOfRange": 5000}, {"entityId": "6425190255558656", "endOfRange": 10000}], "name": "ST | FY26Q1 | Altium | TS-2468 | Homepage - Expand the product cards on Altium homepage", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "5079917512097792"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["5107837618094080"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "5485001211379712", "name": "ST | FY26Q1 | Altium | TS-2469 | Add final bite to Altium homepage", "commitId": "5911679855230976", "groupId": "5571845550768128", "holdback": 0, "activation": {}, "integrationSettings": {"5136150625517568": {}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": null, "audienceName": "Everyone else", "changes": null, "id": "5367234650963968", "integrationSettings": null, "variations": [{"id": "6568784937353216", "name": "Original", "actions": []}, {"id": "6530674383912960", "name": "Variation #1", "actions": [{"viewId": "5046281307947008", "changes": [{"id": "410A90AA-3AF5-4231-B24B-0C728DE9AA46", "type": "append", "selector": "head", "value": "<style>html body .eg-promo-banner {\n    background: #F2F4F6;\n    padding: 24px 0;\n}\n\nhtml body .eg-promo-banner__inner {\n    display: flex;\n    align-items: center;\n    grid-gap: 35px;\n}\n\nhtml body .eg-promo-banner__title {\n    font-weight: 600;\n    font-size: 30px;\n    line-height: 120%;\n    letter-spacing: -5%;\n    vertical-align: middle;\n    color: #000000;\n    margin-bottom: 21px;\n}\n\nhtml body .eg-promo-banner__subtitle {\n    font-weight: 500;\n    font-size: 20px;\n    line-height: 120%;\n    letter-spacing: -5%;\n    vertical-align: middle;\n}\n\nhtml body .eg-promo-banner__image {\n    width: 308px;\n    height: 280px;\n    object-fit: cover;\n    border-radius: 10px;\n}\n\nhtml body .eg-promo-banner__list {\n    padding-left: 0;\n}\n\nhtml body .eg-promo-banner__list li {\n    list-style: none;\n    font-weight: 500;\n    font-size: 16px;\n    line-height: 160%;\n    letter-spacing: -2%;\n    vertical-align: middle;\n    display: flex;\n    grid-gap: 13px;\n    align-items: center;\n    margin-bottom: 8px;\n}\n\nhtml body .eg-promo-banner__icon {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    color: #445577;\n    border: 1px solid #4455771F;\n    padding: 10px;\n    border-radius: 11px;\n}\n\nhtml body .eg-promo-banner__button {\n    margin-top: 12px;\n    min-width: 297px !important;\n    font-weight: 700;\n}\n\n@media screen and (max-width: 992px) {\n    html body .eg-promo-banner__inner::after,\n    html body .eg-promo-banner__inner::before {\n        display: none;\n    }\n\n    html body .eg-promo-banner__media {\n        width: 300px;\n    }\n\n    html body .eg-promo-banner__content {\n        width: calc(100% - 335px);\n    }\n}\n\n@media screen and (max-width: 767px) {\n    html body .eg-promo-banner__inner {\n        flex-direction: column;\n    }\n\n    html body .eg-promo-banner__media,\n    html body .eg-promo-banner__content {\n        width: 100%;\n    }\n\n    html body .eg-promo-banner__image {\n        width: 100%;\n    }\n\n    html body .eg-promo-banner__button {\n        min-width: 100% !important;\n    }\n}</style>", "dependencies": []}, {"id": "71E3FA32-EADA-44F6-9C3B-E013A739F5D5", "type": "custom_code", "value": function($){(function () {
  try {
    /* main variables */
    var debug = 0;
    var variation_name = "";
    var $;
    /* all Pure helper functions */

    function waitForElement(selector, trigger, delayInterval, delayTimeout) {
      var interval = setInterval(function () {
        if (
          document &&
          document.querySelector(selector) &&
          document.querySelectorAll(selector).length > 0
        ) {
          clearInterval(interval);
          trigger();
        }
      }, delayInterval);
      setTimeout(function () {
        clearInterval(interval);
      }, delayTimeout);
    }

    const promoBanner = `
    <div class="eg-promo-banner">
      <div class="eg-promo-banner__inner l-container">
        <div class="eg-promo-banner__media">
          <img
            class="eg-promo-banner__image" src="https://cdn.files.altium.com/sites/default/files/2026-03/develop-upd.webp?VersionId=BJmmJqk.xifBT5hd4fFfqpaE6pAWbLC4" alt="Altium Develop promotional visual"/>
        </div>

        <div class="eg-promo-banner__content">
          <h2 class="eg-promo-banner__title">
            Unify Your Design, Collaboration, and Delivery.
          </h2>

          <p class="eg-promo-banner__subtitle">
            Start your 30-day full evaluation of Altium Develop.<br>
            Everything in one connected platform.
          </p>

          <ul class="eg-promo-banner__list">
            <li class="eg-promo-banner__list-item">
              <span class="eg-promo-banner__icon">✓</span>
              <span class="eg-promo-banner__text">Altium Designer license included.</span>
            </li>
            <li class="eg-promo-banner__list-item">
              <span class="eg-promo-banner__icon">✓</span>
              <span class="eg-promo-banner__text">Start instantly, no credit card needed.</span>
            </li>
          </ul>

          <a href="#" class="eg-promo-banner__button wds-btn _center _medium _primary _m-width-lg">
            Start My 30-Day Trial
          </a>
        </div>
      </div>
    </div>`;

    /* Variation Init */
    function init() {
      document.body.classList.add('EG-TS-2469');
      if (!document.querySelector('.eg-promo-banner')) {
        document.querySelector('#quotes').insertAdjacentHTML('afterend', promoBanner);
      }
    }

    /* Initialize variation */
    waitForElement('#quotes', init, 50, 15000);
  } catch (e) {
    if (debug) console.log(e, "error in Test" + variation_name);
  }
})();
}, "dependencies": []}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "7F5E8F9B-3FEF-44D7-BAF4-7562C917D256", "selector": ".b-plate-columns._use-hover .b-plate-columns__item a"}, {"css": {}, "dependencies": [], "attributes": {}, "type": "attribute", "id": "18623286-B8E6-4B3B-B161-41C95C77552A", "selector": ".header-v2__user__btn"}, {"id": "49085D94-5604-41DF-953D-8A4BBD12466E", "type": "attribute", "dependencies": [], "name": "", "isOpalManaged": false, "selector": ".eg-promo-banner__button", "attributes": {"href": "https://www.altium.com/develop/get-started"}, "css": {}}]}]}], "weightDistributions": [{"entityId": "6568784937353216", "endOfRange": 5000}, {"entityId": "6530674383912960", "endOfRange": 10000}], "name": "ST | FY26Q1 | Altium | TS-2469 | Add final bite to Altium homepage", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "5485001211379712"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["5046281307947008"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "6082830862647296", "name": "ST | FY25Q1 | Altium | TS-2465 | Homepage: Move Trust Up to directly under the fold", "commitId": "6578012976578560", "groupId": "5571845550768128", "holdback": 0, "activation": {}, "integrationSettings": {"5136150625517568": {}}, "integrationStringVersion": 2, "experiments": [{"audienceIds": null, "audienceName": "Everyone else", "changes": null, "id": "6712457129885696", "integrationSettings": null, "variations": [{"id": "6580695519199232", "name": "Original", "actions": []}, {"id": "6530776859148288", "name": "Variation #1", "actions": [{"viewId": "5586557223043072", "changes": [{"id": "52274060-4D97-423F-A61F-AC156EAE6557", "type": "custom_code", "value": function($){(function () {
